# Copy this file to `.env` for local development.
# Do not commit real secrets.

# ─── Frontend ────────────────────────────────────────────────────────────────
VITE_APP_URL=http://localhost:5175
VITE_API_URL=http://localhost:3002
VITE_API_BASE_URL=http://localhost:3002
VITE_BACKEND_URL=http://localhost:3002
VITE_REALTIME_WS_BASE_URL=ws://localhost:3002
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
# Get real price IDs from Stripe Dashboard → Products
VITE_STRIPE_STARTER_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx
VITE_STRIPE_PRO_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_LO_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_LO_PRO_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_DEFAULT_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx

# ─── Mailgun ──────────────────────────────────────────────────────────────────
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=mg.example.com
MAILGUN_FROM_EMAIL=hello@example.com
MAILGUN_FROM_NAME=HomeListingAI
MAILGUN_SIGNING_KEY=your-mailgun-webhook-signing-key
MAILGUN_WEBHOOK_SIGNING_KEY=your-mailgun-webhook-signing-key
MAILGUN_REGION=us

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3002/auth/google/callback

# ─── App URLs ─────────────────────────────────────────────────────────────────
APP_URL=http://localhost:5175
APP_BASE_URL=http://localhost:5175
PUBLIC_URL=http://localhost:5175
PUBLIC_BASE_URL=http://localhost:5175
FRONTEND_URL=http://localhost:5175
BACKEND_BASE_URL=http://localhost:3002
DASHBOARD_BASE_URL=http://localhost:5175

# ─── Internal Security ────────────────────────────────────────────────────────
INTERNAL_JOB_SECRET=generate-a-random-secret-here
INCOMING_LEAD_WEBHOOK_SECRET=generate-a-random-secret-here

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com
NOTIFICATION_EMAIL=admin@yourdomain.com

# ─── SEO / Build ──────────────────────────────────────────────────────────────
SEO_SITE_URL=https://homelistingai.com

# ─── Optional features (leave blank to disable) ───────────────────────────────
HUME_CONFIG_ID=
CENSUS_API_KEY=
TRANSLATE_API_KEY=
GA_PROPERTY_ID=
GA_SERVICE_ACCOUNT_JSON=
VAPI_DEFAULT_ASSISTANT_ID=
VAPI_APPOINTMENT_REMINDER_ASSISTANT_ID=
