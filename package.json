{
  "name": "homelistingai-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "An AI-powered platform for real estate agents to generate stunning property listings with interactive features like an AI assistant.",
  "scripts": {
    "dev": "vite --port 5175",
    "build": "vite build && node scripts/generate-seo-pages.mjs",
    "build:frontend": "vite build && node scripts/generate-seo-pages.mjs",
    "build:check": "tsc && vite build && node scripts/generate-seo-pages.mjs",
    "gate:fe": "npm run typecheck && npm run build",
    "gate:be": "bash -c 'set -euo pipefail; mkdir -p logs; npm --prefix backend run -s start > logs/gate-backend.out 2>&1 & BACK_PID=$!; trap \"kill $BACK_PID 2>/dev/null || true\" EXIT; BASE=http://127.0.0.1:3002 bash scripts/gate_backend_smoke.sh'",
    "gate:all": "npm run gate:fe && npm run gate:be",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test": "TZ=America/Los_Angeles jest",
    "test:backend": "node --test backend/services/__tests__/*.test.js",
    "preview": "vite preview",
    "deploy": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:admin": "tsc -p tsconfig.admin.json --noEmit",
    "verify:mailgun": "node scripts/check-mailgun-config.cjs",
    "ci": "npm run verify:mailgun && npm run lint && npm run typecheck && npm run build",
    "prepare": "husky",
    "start": "cd backend && node server.cjs",
    "start-server": "bash -c 'mkdir -p logs; npm --prefix backend run -s start >> logs/backend.out 2>&1 & echo $! > logs/backend.pid; npm run -s dev >> logs/vite.out 2>&1 & echo $! > logs/vite.pid; echo \"✅ Backend PID $(cat logs/backend.pid); Vite PID $(cat logs/vite.pid)\"'",
    "stop-server": "bash -c 'kill $(cat logs/vite.pid) 2>/dev/null || true; kill $(cat logs/backend.pid) 2>/dev/null || true; kill $(cat logs/preview.pid) 2>/dev/null || true; rm -f logs/*.pid; echo \"✅ Servers stopped\"'"
  },
  "dependencies": {
    "@sentry/node": "^10.56.0",
    "@supabase/supabase-js": "^2.56.1",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^5.1.0",
    "googleapis": "^171.1.0",
    "helmet": "^8.1.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^3.0.4",
    "lucide-react": "^0.552.0",
    "openai": "^5.12.2",
    "pg": "^8.18.0",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^2.0.5",
    "react-hot-toast": "^2.6.0",
    "react-quill": "^2.0.0",
    "react-router-dom": "^6.26.2",
    "react-simple-wysiwyg": "^3.4.1",
    "telnyx": "^4.6.0",
    "three": "^0.184.0",
    "ws": "^8.19.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/quill": "^2.0.14",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@types/three": "^0.184.1",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^15.5.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "terser": "^5.43.1",
    "ts-jest": "^29.4.1",
    "typescript": "5.5.4",
    "vite": "^7.2.2"
  },
  "jest": {
    "preset": "ts-jest",
    "transform": {
      "^.+\\.(ts|tsx)$": [
        "ts-jest",
        {
          "astTransformers": {
            "before": [
              "<rootDir>/src/test/importMetaTransformer.cjs"
            ]
          }
        }
      ]
    },
    "testEnvironment": "jsdom",
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js"
    ],
    "moduleNameMapper": {
      "^.+/lib/env$": "<rootDir>/src/lib/__mocks__/env.ts",
      "^\\.{1,2}/env$": "<rootDir>/src/lib/__mocks__/env.ts"
    },
    "setupFilesAfterEnv": [
      "<rootDir>/src/test/setupTests.ts"
    ],
    "testMatch": [
      "<rootDir>/src/**/*.test.(ts|tsx)"
    ],
    "modulePathIgnorePatterns": [
      "<rootDir>/.claude/"
    ]
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix --max-warnings=0"
    ]
  }
}
